generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id String @unique @default(nanoid())

  email    String @unique
  password String

  name   String
  avatar String @default("https://i.pravatar.cc/150")
  bio    String

  notificationNewComments         Boolean @default(true) @map("notification_new_comments")
  notificationLikes               Boolean @default(true) @map("notification_likes")
  notificationNewTrackInFavorites Boolean @default(false) @map("notification_new_track_in_favorites")

  tracks    Track[]
  comments  Comment[]
  favorites Favorite[]
  likes     Like[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("accounts")
}

model Favorite {
  id String @unique @default(nanoid())

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String  @map("account_id")

  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId String @map("track_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([accountId, trackId])
  @@index([accountId])
  @@index([trackId])
  @@map("favorites")
}

model Like {
  id String @unique @default(nanoid())

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String  @map("account_id")

  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId String @map("track_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([accountId, trackId]) // Один пользователь может поставить лайк только один раз
  @@map("likes")
}

model Track {
  id String @unique @default(nanoid())

  title String @unique

  region     String
  tags       String[]
  text       String
  excerpt    String
  images     String[]
  date       DateTime
  likes      Int
  lat        Float
  lng        Float
  duration   String
  difficulty String

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String  @map("account_id")

  comments  Comment[]
  favorites Favorite[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  likesList Like[]

  @@index([accountId])
  @@map("tracks")
}

model Comment {
  id String @unique @default(nanoid())

  author String
  text   String

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String  @map("account_id")

  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId String @map("track_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([trackId]) // поиск комментариев к треку
  @@index([accountId]) // поиск комментариев пользователя
  @@map("comments")
}
